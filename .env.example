# ═══════════════════════════════════════════════════════════════════════════
# nyxara-core — Environment Variables
# Copy this file to .env and adjust values for your local setup.
# (RESET 2026-07: harvester/scraper secrets removed. Re-add per phase as needed.)
# ═══════════════════════════════════════════════════════════════════════════

# ── Inference provider (OpenAI-compatible) ─────────────────────────────────
INFERENCE_PROVIDER=ollama
INFERENCE_MODEL=hermes3
INFERENCE_BASE_URL=http://localhost:11434/v1
# For local Ollama this value is unused.
# To use OpenAI: set BASE_URL=https://api.openai.com/v1 and put your key here.
INFERENCE_API_KEY=ollama

# ── Vector DB (Qdrant) ────────────────────────────────────────────────────
QDRANT_URL=http://localhost:6353

# ── Cache / Broker (Redis) ────────────────────────────────────────────────
REDIS_URL=redis://localhost:6399/0

# ── Application ───────────────────────────────────────────────────────────
# APP_NAME=nyxara-core
# APP_VERSION=0.1.0
# DEBUG=false
# LOG_LEVEL=INFO
